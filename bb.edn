{:paths     ["src" "resources" "dev"]
 :deps      {}
 :bbin/bin  {clef {:main-opts ["-f" "clef"]}}
 :tasks
 {test       {:doc  "Run unit tests via Cognitect test-runner"
              :task (shell "clojure -X:test")}
  lint       {:doc  "Run clj-kondo on src + test + dev"
              :task (shell "clj-kondo --lint src test dev")}
  clef       {:doc  "Run clef from source (via clojure) — for local dev"
              :task (apply shell "clojure -M -m clef.main" *command-line-args*)}
  gen-script {:doc  "Generate the single-file clef bb script at ./clef"
              :requires ([clef.gen-script :as gen])
              :task (gen/gen-script)}}}
